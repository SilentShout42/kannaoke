{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kannaoke Performances",
  "type": "object",
  "required": ["performances"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "performances": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["videoId", "startTime", "title", "artist", "videoTitle", "videoDate"],
        "additionalProperties": false,
        "properties": {
          "videoId": {
            "type": "string",
            "description": "YouTube video ID",
            "pattern": "^[a-zA-Z0-9_-]{11}$"
          },
          "startTime": {
            "type": "integer",
            "minimum": 0
          },
          "endTime": {
            "type": ["integer", "null"],
            "minimum": 0
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "artist": {
            "type": "string",
            "description": "Original artist(s), multiple separated by ' · '",
            "minLength": 1
          },
          "videoTitle": {
            "type": "string",
            "minLength": 1
          },
          "videoDate": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "membersOnly": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
