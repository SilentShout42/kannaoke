{
  "name": "kannaoke",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "prepare:data": "node scripts/build-performances.mjs",
    "prepare:data:watch": "node scripts/watch-performances.mjs",
    "dev": "npm run prepare:data && (npm run prepare:data:watch & vite)",
    "build": "npm run prepare:data && tsc -b && vite build",
    "preview": "npm run build && wrangler dev --config dist/kannaoke/wrangler.json",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.42.0",
    "fuse.js": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-lite-youtube-embed": "^3.5.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "ajv": "^8.20.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
